{
  "info": {
    "name": "BoviTrack API",
    "description": "Colección de endpoints para BoviTrack — Sistema de gestión ganadera",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/",
            "header": []
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@bovitrack.com\",\n  \"first_name\": \"Juan\",\n  \"last_name\": \"Pérez\",\n  \"document_type\": \"CC\",\n  \"document_number\": \"1234567890\",\n  \"phone\": \"3001234567\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('access_token', json.access_token);",
                  "  pm.collectionVariables.set('refresh_token', json.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@bovitrack.com\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('access_token', json.access_token);",
                  "  pm.collectionVariables.set('refresh_token', json.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/refresh",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/forgot-password",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@bovitrack.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/reset-password",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"TOKEN_AQUI\",\n  \"new_password\": \"NewPassword123!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/users/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Farms",
      "item": [
        {
          "name": "Create Farm",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/farms",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Hacienda El Porvenir\",\n  \"address\": \"Vereda La Esperanza, Km 5\",\n  \"department_id\": \"UUID_DEPARTAMENTO\",\n  \"city_id\": null,\n  \"total_area\": 150.5,\n  \"area_unit\": \"hectareas\",\n  \"purpose_id\": \"UUID_PROPOSITO\",\n  \"farm_identifier\": \"FIN-001\",\n  \"phone\": \"3001234567\"\n}"
            }
          }
        },
        {
          "name": "List My Farms",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/farms",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ]
          }
        },
        {
          "name": "Get Farm Detail",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/farms/{{farm_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ]
          }
        }
      ]
    }
  ]
}
