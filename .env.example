# ══════════════════════════════════════════════════════════════
# BoviTrack — Plantilla de variables de entorno
#
# ¿Qué?    Copia este archivo como .env y completa los valores.
# ¿Para?   Sirve de referencia documentada para cualquier
#           desarrollador que clone el repositorio.
# ¿Impacto? Sin este archivo, quien clona el repo no sabe qué
#           variables son necesarias ni qué formato tienen.
# ══════════════════════════════════════════════════════════════

# ─── Base de datos ────────────────────────────────
POSTGRES_USER=<usuario_de_la_bd>
POSTGRES_PASSWORD=<contraseña_segura>
POSTGRES_DB=<nombre_de_la_bd>

# ─── JWT ──────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<clave_secreta_aleatoria_minimo_32_chars>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── URLs ─────────────────────────────────────────
# Con Docker (fe en nginx:80): http://localhost
# Sin Docker (Vite dev): http://localhost:5173
FRONTEND_URL=http://localhost
# Con Docker (nginx proxia /api/): /api/v1
# Sin Docker (acceso directo): http://localhost:8000/api/v1
VITE_API_URL=/api/v1
